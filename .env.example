# ─── TESSERACT (OCR for images and scanned PDFs) ───────────
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── POPPLER (PDF to image conversion) ─────────────────────
POPPLER_PATH=C:\path\to\poppler\Library\bin

# ─── FFMPEG (audio/video processing) ───────────────────────
FFMPEG_PATH=C:\path\to\ffmpeg\bin

# ─── WHISPER (speech to text) ──────────────────────────────
WHISPER_MODEL=base
# options: tiny, base, small, medium, large

# ─── EMBEDDINGS ─────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# alternatives:
# sentence-transformers/all-mpnet-base-v2
# sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── CHUNKING ───────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── VECTOR STORE ───────────────────────────────────────────
FAISS_INDEX_PATH=./faiss_index

# ─── LLM PROVIDER ───────────────────────────────────────────
# options: gemini, openai, claude
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (if using LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Claude (if using LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-sonnet-4-6

# ─── VISION MODEL (for video frame description) ─────────────
# Florence-2 runs locally, no API key needed
FLORENCE_MODEL=microsoft/Florence-2-base
# options: microsoft/Florence-2-base, microsoft/Florence-2-large

# ─── STORAGE ────────────────────────────────────────────────
STORAGE_BACKEND=local
# options: local, s3

# S3 (if using STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET_NAME=your_bucket